# GEMINI_API_KEY — sem prefixo VITE_, fica APENAS no servidor (Netlify Function)
# Esta chave NUNCA será exposta no browser ou no bundle do JavaScript
# Para desenvolvimento local com netlify dev, use este arquivo (copie para .env e preencha)
# Para produção: Netlify → Site Settings → Environment Variables → GEMINI_API_KEY
GEMINI_API_KEY=your_gemini_api_key_here

# SUPABASE (opcional — para logging de conversas)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
